{
  "name": "golden-dollar-consultancy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/patchFs.cjs ./node_modules/next/dist/bin/next dev",
    "prebuild": "node scripts/fixPermissions.cjs",
    "build": "prisma generate && node -r ./scripts/patchFs.cjs ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "deploy:zip": "node scripts/createDeployment.cjs"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dropbox": "^10.34.0",
    "lucide-react": "^0.394.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "archiver": "^5.3.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.39",
    "prisma": "^5.16.1",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
