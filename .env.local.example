# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development (file-based, no setup needed)
DATABASE_URL="file:./dev.db"

# ─── Dropbox Integration ───────────────────────────────────────────────────────
# Option 1 – Simple access token (for development / testing)
# Get from: https://www.dropbox.com/developers/apps → your app → Generated access token
DROPBOX_ACCESS_TOKEN=your-dropbox-long-lived-access-token

# Option 2 – OAuth2 (recommended for production)
# DROPBOX_APP_KEY=your-app-key
# DROPBOX_APP_SECRET=your-app-secret
# DROPBOX_REFRESH_TOKEN=your-refresh-token

# ─── Email / SMTP — Microsoft Outlook / Office 365 ────────────────────────────
# Use the full Outlook email as SMTP_USER and your Outlook password as SMTP_PASS
# If MFA is enabled, create an App Password at: account.microsoft.com → Security → App passwords
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=priti@goldendollarconsulting.com
SMTP_PASS=your-outlook-password-or-app-password
SMTP_FROM=Golden Dollar Consultancy <priti@goldendollarconsulting.com>
SUPPORT_EMAIL=itsupport@goldendollarconsulting.com

# ─── Seed Passwords (used only when running: npm run db:seed) ──────────────────
ADMIN_SEED_PASSWORD=GDC@Admin2025!
IT_SEED_PASSWORD=GDC@ITSupport2025!
